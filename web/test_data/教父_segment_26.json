{
    "movie_id": "4",
    "movie_title": "教父",
    "segment_index": 26,
    "genre": "剧情, 犯罪, 黑帮",
    "year": "1972",
    "director": "Francis Ford Coppola",
    "actors": [
        "Marlon Brando",

{
    "movie_id": "1",
    "movie_title": "阿甘正传",
    "segment_index": 77,
    "genre": "剧情, 爱情, 励志",
    "year": "1994",
    "director": "Robert Zemeckis",
    "actors": [
        "Tom Hanks",
        "Robin Wright",
        "Gary Sinise"
    ],
    "tags": [
        "励志",

{
    "movie_id": "5",
    "movie_title": "肖申克的救赎",
    "segment_index": 96,
    "genre": "剧情, 犯罪",
    "year": "1994",
    "director": "Frank Darabont",
    "actors": [
        "Tim Robbins",
        "Morgan Freeman",
        "Bob Gunton"

{
    "movie_id": "6",
    "movie_title": "星际穿越",
    "segment_index": 52,
    "genre": "科幻, 冒险, 剧情",
    "year": "2014",
    "director": "Christopher Nolan",
    "actors": [
        "Matthew McConaughey",

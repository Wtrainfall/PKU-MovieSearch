{
    "movie_id": "3",
    "movie_title": "盗梦空间",
    "segment_index": 57,
    "genre": "动作, 科幻, 悬疑",
    "year": "2010",
    "director": "Christopher Nolan",
    "actors": [
        "Leonardo DiCaprio",
        "Joseph Gordon-Levitt",

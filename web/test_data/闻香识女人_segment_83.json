{
    "movie_id": "7",
    "movie_title": "闻香识女人",
    "segment_index": 83,
    "genre": "剧情",
    "year": "1992",
    "director": "Martin Brest",
    "actors": [
        "Al Pacino",
        "Chris O'Donnell",
        "James Rebhorn"
